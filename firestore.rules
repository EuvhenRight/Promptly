// Раніше було тимчасово: allow read, write для всіх авторизованих.
// Нижче — повні правила для продакшену: користувачі, кошики, замовлення,
// промпти, категорії, приватний контент, коментарі.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasPurchased(promptId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.purchasedPrompts.hasAny([promptId]);
    }

    // ----------------------------------------------------------------------
    // Collections
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/carts/{cartId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /private/{docId} {
        allow get: if docId == 'content' && (isAdmin() || hasPurchased(promptId));
        allow write: if docId == 'content' && isAdmin();
      }

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if hasPurchased(promptId);
        allow update, delete: if isOwner(resource.data.userId);
      }
    }

    match /scraped_prompts/{sourceId} {
      allow read, write: if isAdmin();
    }
  }
}
