rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function hasPurchased(promptId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('purchasedPrompts', []).hasAny([promptId]);
    }

    // Safely checks if a stat is being changed by a certain amount.
    function isChangingStatBy(stat, by) {
        let currentStatValue = 0;
        // Safely get the old value, defaulting to 0 if stats or the specific stat doesn't exist.
        if ('stats' in resource.data && resource.data.stats != null && stat in resource.data.stats) {
            currentStatValue = resource.data.stats[stat];
        }
        
        // The new value must exist in the request.
        if (!('stats' in request.resource.data) || !(stat in request.resource.data.stats)) {
          return false;
        }
        let nextStatValue = request.resource.data.stats[stat];

        return nextStatValue == currentStatValue + by;
    }

    // Safely checks that ONLY a specific stat field inside the 'stats' map is being changed.
    function isOnlyChangingStat(stat) {
      let allAffectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      
      // Ensure only the 'stats' map is being changed at the top level.
      if (!allAffectedKeys.hasOnly(['stats'])) {
        return false;
      }
      
      // If 'stats' didn't exist before, the new map must only contain the target stat.
      if (!('stats' in resource.data) || resource.data.stats == null) {
        return request.resource.data.stats.keys().hasOnly([stat]);
      }
      
      // If 'stats' existed, diff it to see what changed inside.
      let statsAffectedKeys = request.resource.data.stats.diff(resource.data.stats).affectedKeys();
      return statsAffectedKeys.hasOnly([stat]);
    }


    function isOnlyChangingFavorites() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoritePrompts']);
    }


    // ----------------------------------------------------------------------
    // Collection Group Rules
    // ----------------------------------------------------------------------

    match /{path=**}/comments/{commentId} {
      allow list: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Collections
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if
        (isOwner(userId) && isOnlyChangingFavorites()) ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'followers', 'following', 'views'])) ||
        isAdmin();
      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == followerId;
      }
      match /following/{followingId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /public-profiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update: if
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'followers', 'following']))
        || (isOnlyChangingStat('views') && isChangingStatBy('views', 1))
        || (isSignedIn() && isOnlyChangingStat('followers') && (isChangingStatBy('followers', 1) || isChangingStatBy('followers', -1)))
        || (isOwner(userId) && isOnlyChangingStat('following') && (isChangingStatBy('following', 1) || isChangingStatBy('following', -1)));
    }

    match /users/{userId}/carts/{cartId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/purchaseHistory/{path=**} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/orders/{orderId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /types/{typeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /models/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow get, list: if true;
      allow create, delete: if isAdmin();
      allow update: if
        isAdmin()
        // Allow anyone (even unauth) to increment views
        || (isOnlyChangingStat('views') && isChangingStatBy('views', 1))
        // Allow signed-in users to like/unlike
        || (isSignedIn() && isOnlyChangingStat('likes') && (isChangingStatBy('likes', 1) || isChangingStatBy('likes', -1)))
        // Allow a user to increment sales by 1, but only if they haven't purchased it yet.
        // This is part of the purchase transaction.
        || (isSignedIn() && !hasPurchased(promptId) && isOnlyChangingStat('sales') && isChangingStatBy('sales', 1))
        // Allow a user who purchased the prompt to update its rating
        || ((hasPurchased(promptId) || resource.data.price == 0) && request.resource.data.rating != resource.data.rating && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating']));


      match /private/{docId} {
        allow get: if docId == 'content' && (isAdmin() || hasPurchased(promptId));
        allow write: if docId == 'content' && isAdmin();
      }

      match /comments/{commentId} {
        allow get, list: if true;

        // CREATE: User can create a comment IF they own the comment ID AND
        // they are an admin OR have purchased/free access.
        allow create: if isOwner(commentId) && (isAdmin() || hasPurchased(promptId) || get(/databases/$(database)/documents/prompts/$(promptId)).data.price == 0);

        // UPDATE/DELETE: User can modify their own comment or an admin can.
        allow update, delete: if isAdmin() || isOwner(commentId);
      }
    }

    match /scraped_prompts/{sourceId} {
      allow read, write: if isAdmin();
    }

    match /searchBarBackgrounds/{bgId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
