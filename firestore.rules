rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasPurchased(promptId) {
      let userDocData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let purchased = userDocData.get('purchasedPrompts', []);
      return isSignedIn() && purchased.hasAny([promptId]);
    }

    // ----------------------------------------------------------------------
    // Collection Group & Independent Rules
    // ----------------------------------------------------------------------

    match /{path=**}/comments/{commentId} {
      allow list: if isAdmin();
    }
    
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow write: if false; 
    }

    // ----------------------------------------------------------------------
    // Collections
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if
        isAdmin() ||
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoritePrompts'])) ||
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['planWillCancelAtPeriodEnd'])) ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'credits', 'earnings', 'payoutStatus', 'purchasedPrompts', 'followers', 'following', 'views', 'planId']));
      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == followerId;
      }
      match /following/{followingId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /public-profiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update: if 
        isAdmin() ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'followers', 'following'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && request.resource.data.views == resource.data.views + 1) ||
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) && (request.resource.data.followers == resource.data.followers + 1 || request.resource.data.followers == resource.data.followers - 1)) ||
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following']) && (request.resource.data.following == resource.data.following + 1 || request.resource.data.following == resource.data.following - 1));
    }

    match /users/{userId}/carts/{cartId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/purchaseHistory/{path=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/orders/{orderId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /types/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /models/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read, list, update: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow list: if true;
      allow get: if resource.data.isPrivate != true || (isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planId == 'pro' || isAdmin()));
      allow create, delete: if isAdmin();
      allow update: if
        isAdmin() ||
        ( // Rule for views: anyone can increment by 1
          request.resource.data.stats.diff(resource.data.stats).affectedKeys().hasOnly(['views']) &&
          request.resource.data.stats.views == resource.data.stats.views + 1
        ) ||
        ( // Rule for likes: signed-in users can increment/decrement by 1
          isSignedIn() &&
          request.resource.data.stats.diff(resource.data.stats).affectedKeys().hasOnly(['likes']) &&
          (request.resource.data.stats.likes == resource.data.stats.likes + 1 || request.resource.data.stats.likes == resource.data.stats.likes - 1)
        ) ||
        ( // Rule for rating: purchased users can update rating
          (hasPurchased(promptId) || resource.data.price == 0) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating'])
        );


      match /private/{docId} {
        allow get: if docId == 'content' && (isAdmin() || hasPurchased(promptId));
        allow write: if docId == 'content' && isAdmin();
      }

      match /comments/{commentId} {
        allow get, list: if true;
        // Allow creation if user has purchased, the prompt is free, or user is an admin.
        allow create: if isSignedIn() && (hasPurchased(promptId) || get(/databases/$(database)/documents/prompts/$(promptId)).data.price == 0 || isAdmin());
        // Allow update/delete if user is the author of the comment or an admin.
        allow update, delete: if isOwner(request.resource.data.userId) || isAdmin();
      }
    }

    match /scraped_prompts/{sourceId} {
      allow read, write: if isAdmin();
    }

    match /searchBarBackgrounds/{bgId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
