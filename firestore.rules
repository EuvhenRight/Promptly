rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function hasPurchased(promptId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        'purchasedPrompts' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.purchasedPrompts is list &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.purchasedPrompts.hasAny([promptId]);
    }
    
    // ----------------------------------------------------------------------
    // Collection Group & Independent Rules
    // ----------------------------------------------------------------------

    match /{path=**}/comments/{commentId} {
      allow list: if isAdmin();
    }
    
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn() && request.resource.data.userId == userId;
      allow update, delete: if false; 
    }

    // ----------------------------------------------------------------------
    // Collections
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth.uid == userId && request.resource.data.uid == userId;
      allow update: if
        isAdmin() ||
        // Regular profile updates (no critical fields)
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'credits', 'earnings', 'payoutStatus', 'purchasedPrompts', 'followers', 'following', 'views', 'planId', 'planPurchasedAt', 'planBillingPeriod', 'planWillCancelAtPeriodEnd'])) ||
        // Payout request transaction
        (
          isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits', 'payoutStatus']) &&
          request.resource.data.payoutStatus == 'pending' &&
          request.resource.data.credits < resource.data.credits
        );
      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && (request.auth.uid == followerId || request.auth.uid == userId);
      }
      match /following/{followingId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == followingId);
      }
    }

    match /public-profiles/{userId} {
      allow get, list: if true;
      allow create: if request.auth.uid == userId && request.resource.data.uid == userId;
      allow update: if 
        isAdmin() ||
        // Owner can update their profile, but not the counters/plan
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'followers', 'following', 'planId'])) ||
        // Anyone can increment views
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && request.resource.data.views == resource.data.views + 1) ||
        // Any signed-in user can change a followers/following count by +/- 1
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) && (request.resource.data.followers == resource.data.followers + 1 || request.resource.data.followers == resource.data.followers - 1)) ||
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following']) && (request.resource.data.following == resource.data.following + 1 || request.resource.data.following == resource.data.following - 1));
    }

    match /users/{userId}/carts/{cartId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/purchaseHistory/{path=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/orders/{orderId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /types/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /models/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read, list, update: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    match /sales/{saleId} {
      allow read, write: if false;
    }

    match /prompts/{promptId} {
      allow list: if true;
      // Allow read if prompt is not private OR user has a pro plan OR user is an admin
      allow get: if resource.data.isPrivate != true || (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planId == 'pro'
      ) || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if
        isAdmin() ||
        ( // Rule for views: anyone can increment views by 1
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']) &&
          request.resource.data.stats.views == resource.data.stats.views + 1 &&
          request.resource.data.stats.likes == resource.data.stats.likes &&
          request.resource.data.stats.sales == resource.data.stats.sales
        ) ||
        ( // Rule for likes: signed-in users can increment/decrement likes by 1
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']) &&
          (request.resource.data.stats.likes == resource.data.stats.likes + 1 || request.resource.data.stats.likes == resource.data.stats.likes - 1) &&
          request.resource.data.stats.views == resource.data.stats.views &&
          request.resource.data.stats.sales == resource.data.stats.sales
        ) ||
        ( // Rule for rating: purchased users can update rating
          (hasPurchased(promptId) || resource.data.price == 0 || isAdmin()) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating'])
        );


      match /private/{docId} {
        allow get: if docId == 'content' && (isAdmin() || hasPurchased(promptId));
        allow write: if docId == 'content' && isAdmin();
      }

      match /comments/{commentId} {
        allow get, list: if true;
        // Allow creation if user has purchased, the prompt is free, or user is an admin.
        allow create: if isSignedIn() && (hasPurchased(promptId) || resource.data.price == 0 || isAdmin());
        // Allow update/delete if user is the author of the comment or an admin.
        allow update, delete: if isOwner(resource.data.userId) || isAdmin();
      }
    }

    match /scraped_prompts/{sourceId} {
      allow read, write: if isAdmin();
    }

    match /searchBarBackgrounds/{bgId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
