rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Correct, reliable way to check for admin role using custom claims.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Use .get('purchasedPrompts', []) so missing field does not cause rule failure
    function hasPurchased(promptId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('purchasedPrompts', []).hasAny([promptId]);
    }
    
    function isOnlyChanging(key) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([key]);
    }

    function isIncrementing(field, by) {
      return request.resource.data[field] == (resource.data[field] || 0) + by;
    }
    
    function isOnlyChangingStat(stat, by) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']) &&
             request.resource.data.stats.diff(resource.data.stats).affectedKeys().hasOnly([stat]) &&
             request.resource.data.stats[stat] == (resource.data.stats[stat] || 0) + by;
    }


    // ----------------------------------------------------------------------
    // Collection Group Rules
    // ----------------------------------------------------------------------

    // This rule allows admins to list all comments across all prompts for the admin panel.
    match /{path=**}/comments/{commentId} {
      allow list: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Collections
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      // Allow a user to update their own profile, but NOT their role.
      // Allow anyone to increment views or follower counts.
      // Allow owner to increment their own following count.
      allow update: if
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && request.resource.data.views == (resource.data.views || 0) + 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) && request.resource.data.followers == (resource.data.followers || 0) + 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) && request.resource.data.followers == (resource.data.followers || 0) - 1) ||
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following']) && request.resource.data.following == (resource.data.following || 0) + 1) ||
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following']) && request.resource.data.following == (resource.data.following || 0) - 1);
      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow get, list: if true;
        allow create, delete: if request.auth.uid == followerId;
      }
      match /following/{followingId} {
        allow get, list: if true;
        allow create, delete: if request.auth.uid == userId;
      }
    }

    match /public-profiles/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth.uid == userId;
      allow update: if
        request.auth.uid == userId ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && request.resource.data.views == (resource.data.views || 0) + 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) && request.resource.data.followers == (resource.data.followers || 0) + 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) && request.resource.data.followers == (resource.data.followers || 0) - 1);
    }

    match /users/{userId}/carts/{cartId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/orders/{orderId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /types/{typeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /models/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow get, list: if true;
      allow create, delete: if isAdmin();
      allow update: if 
        isAdmin() ||
        (isSignedIn() && isOnlyChangingStat('likes', 1)) ||
        (isSignedIn() && isOnlyChangingStat('likes', -1)) ||
        (isOnlyChangingStat('views', 1)) ||
        (
          (hasPurchased(promptId) || resource.data.price == 0) &&
          request.resource.data.rating != resource.data.rating && isOnlyChanging('rating')
        );

      match /private/{docId} {
        allow get: if docId == 'content' && (isAdmin() || hasPurchased(promptId));
        allow write: if docId == 'content' && isAdmin();
      }

      match /comments/{commentId} {
        allow get, list: if true;
        
        // CREATE: User can create a comment IF they have purchased/free access
        // AND the comment ID is their own UID. This enforces one comment per user.
        allow create: if (hasPurchased(promptId) || get(/databases/$(database)/documents/prompts/$(promptId)).data.price == 0)
                      && isOwner(commentId);
                      
        // UPDATE/DELETE: User can modify their own comment (identified by doc ID) or an admin can.
        allow update, delete: if isAdmin() || isOwner(commentId);
      }
    }

    match /scraped_prompts/{sourceId} {
      allow read, write: if isAdmin();
    }

    match /searchBarBackgrounds/{bgId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
