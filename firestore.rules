rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasPurchased(promptId) {
      let userDocData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let purchased = userDocData.get('purchasedPrompts', []);
      return isSignedIn() && purchased.hasAny([promptId]);
    }

    // ----------------------------------------------------------------------
    // Collection Group Rules
    // ----------------------------------------------------------------------

    match /{path=**}/comments/{commentId} {
      allow list: if isAdmin();
    }
    
    // Independent rule for user notifications to avoid parent rule conflicts
    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth.uid == userId;
      allow write: if false; // Only server can write notifications
    }

    // ----------------------------------------------------------------------
    // Collections
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      // Allow updates under specific, secure conditions
      allow update: if
        // 1. Admins can do anything.
        isAdmin() ||
        // 2. The user is toggling a favorite prompt (only the 'favoritePrompts' array can change).
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoritePrompts'])) ||
        // 3. The user is managing their subscription cancellation status.
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['planWillCancelAtPeriodEnd'])) ||
        // 4. The user is updating their own profile, but NOT protected fields.
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'credits', 'earnings', 'payoutStatus', 'purchasedPrompts', 'followers', 'following', 'views', 'planId']));

      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == followerId;
      }
      match /following/{followingId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /public-profiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update: if
        isAdmin() ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'followers', 'following'])) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
          request.resource.data.views == resource.data.get('views', 0) + 1
        ) ||
        (
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) &&
          (request.resource.data.followers == resource.data.get('followers', 0) + 1 || request.resource.data.followers == resource.data.get('followers', 0) - 1)
        ) ||
        (
          isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following']) &&
          (request.resource.data.following == resource.data.get('following', 0) + 1 || request.resource.data.following == resource.data.get('following', 0) - 1)
        );
    }

    match /users/{userId}/carts/{cartId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/purchaseHistory/{path=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/orders/{orderId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /types/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /models/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read, list, update: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow list: if true;
      allow get: if resource.data.isPrivate != true || (isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planId == 'pro' || isAdmin()));
      allow create, delete: if isAdmin();
      allow update: if
        isAdmin() ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']) &&
          request.resource.data.stats.views == resource.data.get(['stats', 'views'], 0) + 1 &&
          request.resource.data.stats.sales == resource.data.get(['stats', 'sales'], 0) &&
          request.resource.data.stats.likes == resource.data.get(['stats', 'likes'], 0)
        ) ||
        (
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']) &&
          (request.resource.data.stats.likes == resource.data.get(['stats', 'likes'], 0) + 1 || request.resource.data.stats.likes == resource.data.get(['stats', 'likes'], 0) - 1) &&
          request.resource.data.stats.sales == resource.data.get(['stats', 'sales'], 0) &&
          request.resource.data.stats.views == resource.data.get(['stats', 'views'], 0)
        ) ||
        ((hasPurchased(promptId) || resource.data.price == 0) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating']));

      match /private/{docId} {
        allow get: if docId == 'content' && (isAdmin() || hasPurchased(promptId));
        allow write: if docId == 'content' && isAdmin();
      }

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if (isOwner(commentId) && (hasPurchased(promptId) || get(/databases/$(database)/documents/prompts/$(promptId)).data.price == 0)) || isAdmin();
        allow update, delete: if isOwner(commentId) || isAdmin();
      }
    }

    match /scraped_prompts/{sourceId} {
      allow read, write: if isAdmin();
    }

    match /searchBarBackgrounds/{bgId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
