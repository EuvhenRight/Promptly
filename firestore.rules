rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Use .get() to safely access role from Firestore, as claims can be stale.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasPurchased(promptId) {
      // Safely check if the user has purchased the prompt.
      // Defaults to an empty list if 'purchasedPrompts' does not exist.
      let userDocData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let purchased = userDocData.get('purchasedPrompts', []);
      return isSignedIn() && purchased.hasAny([promptId]);
    }

    // Safely checks if a stat is being changed by a certain amount.
    // Handles cases where the 'stats' map or the stat field itself doesn't exist yet.
    function isChangingStatBy(stat, by) {
        let currentStatValue = resource.data.get('stats', {}).get(stat, 0);

        if (!('stats' in request.resource.data) || !(stat in request.resource.data.stats)) {
          return false;
        }
        let nextStatValue = request.resource.data.stats[stat];

        return nextStatValue == currentStatValue + by;
    }

    // Safely checks that ONLY a specific stat field inside the 'stats' map is being changed.
    function isOnlyChangingStat(stat) {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      
      if (!affected.hasOnly(['stats'])) {
        return false;
      }
      
      let oldStats = resource.data.get('stats', {});
      let newStats = request.resource.data.stats;

      let viewsUnchanged = oldStats.get('views', 0) == newStats.get('views', 0);
      let likesUnchanged = oldStats.get('likes', 0) == newStats.get('likes', 0);
      let salesUnchanged = oldStats.get('sales', 0) == newStats.get('sales', 0);

      if (stat == 'views') {
        return likesUnchanged && salesUnchanged;
      }
      if (stat == 'likes') {
        return viewsUnchanged && salesUnchanged;
      }
      if (stat == 'sales') {
        return viewsUnchanged && likesUnchanged;
      }
      
      return false;
    }

    // Returns true if the only fields being changed are 'credits' and 'purchasedPrompts'.
    // This is a secure way to allow the purchase transaction on the user's document.
    function isCompletingPurchase() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasAll(['credits', 'purchasedPrompts']) && changedKeys.size() == 2;
    }


    // ----------------------------------------------------------------------
    // Collection Group Rules
    // ----------------------------------------------------------------------

    match /{path=**}/comments/{commentId} {
      allow list: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Collections
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      // Allow updates under specific, secure conditions
      allow update: if
        // 1. Admins can do anything.
        isAdmin() ||
        // 2. The user is updating their own profile, but NOT protected fields.
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'credits', 'purchasedPrompts', 'followers', 'following', 'views'])) ||
        // 3. The user is completing a purchase (only credits and purchasedPrompts can change).
        (isOwner(userId) && isCompletingPurchase()) ||
        // 4. The user is toggling a favorite prompt.
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoritePrompts']));

      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == followerId;
      }
      match /following/{followingId} {
        allow get, list: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /public-profiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update: if
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'followers', 'following']))
        || (isOnlyChangingStat('views') && isChangingStatBy('views', 1))
        || (isSignedIn() && isOnlyChangingStat('followers') && (isChangingStatBy('followers', 1) || isChangingStatBy('followers', -1)))
        || (isOwner(userId) && isOnlyChangingStat('following') && (isChangingStatBy('following', 1) || isChangingStatBy('following', -1)));
    }

    match /users/{userId}/carts/{cartId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/purchaseHistory/{path=**} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/orders/{orderId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /types/{typeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /models/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow get, list: if true;
      allow create, delete: if isAdmin();
      allow update: if
        isAdmin()
        // Allow anyone (even unauth) to increment views
        || (isOnlyChangingStat('views') && isChangingStatBy('views', 1))
        // Allow signed-in users to like/unlike
        || (isSignedIn() && isOnlyChangingStat('likes') && (isChangingStatBy('likes', 1) || isChangingStatBy('likes', -1)))
        // Allow a user to increment sales by 1, but only if they haven't purchased it yet.
        // This is part of the purchase transaction.
        || (isSignedIn() && !hasPurchased(promptId) && isOnlyChangingStat('sales') && isChangingStatBy('sales', 1))
        // Allow a user who purchased the prompt to update its rating
        || ((hasPurchased(promptId) || resource.data.price == 0) && request.resource.data.rating != resource.data.rating && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating']));


      match /private/{docId} {
        allow get: if docId == 'content' && (isAdmin() || hasPurchased(promptId));
        allow write: if docId == 'content' && isAdmin();
      }

      match /comments/{commentId} {
        allow get, list: if true;

        // CREATE: User can create a comment IF they own the comment ID AND
        // they are an admin OR have purchased/free access.
        allow create: if isOwner(commentId) && (isAdmin() || hasPurchased(promptId) || get(/databases/$(database)/documents/prompts/$(promptId)).data.price == 0);

        // UPDATE/DELETE: User can modify their own comment or an admin can.
        allow update, delete: if isAdmin() || isOwner(commentId);
      }
    }

    match /scraped_prompts/{sourceId} {
      allow read, write: if isAdmin();
    }

    match /searchBarBackgrounds/{bgId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
